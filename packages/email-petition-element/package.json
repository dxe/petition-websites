    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.8.2",
    "vite": "^6.0.0"
  }
